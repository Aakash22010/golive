# ----------------------------------------------------------------------------
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored — NEVER commit real secrets.
# In production (Vercel), set these in Project Settings -> Environment Variables.
# ----------------------------------------------------------------------------

# --- Supabase (Project Settings -> API) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service-role key bypasses Row Level Security. SERVER-ONLY. Never expose to the browser,
# never prefix with NEXT_PUBLIC_, never commit.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# --- LiveKit (LiveKit Cloud dashboard -> Settings -> Keys) ---
# Public websocket URL used by the browser:
NEXT_PUBLIC_LIVEKIT_URL=wss://your-project.livekit.cloud
# HTTPS host used server-side by the Egress (recording) client:
LIVEKIT_HOST=https://your-project.livekit.cloud
# API key/secret — SERVER-ONLY:
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret

# --- S3-compatible storage for recordings ---
# Supabase Storage is S3-compatible: Project Settings -> Storage -> S3 Connection.
# Create a bucket named `recordings` first (keep it Private).
S3_ENDPOINT=https://YOUR-PROJECT.supabase.co/storage/v1/s3
S3_REGION=us-east-1
S3_BUCKET=recordings
S3_ACCESS_KEY=your-s3-access-key-id
S3_SECRET_KEY=your-s3-secret-access-key

# --- App ---
# Used to build absolute URLs; set to your real domain in production.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
